PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/carbon-tool

# JWT_SECRET debe ser IDÉNTICO al del auth-hub central (ambientapp-landing/server)
# y al del resto de apps (Valorizapp, Eria) — es el que valida la cookie
# ambient_token compartida. Ya no se usan tokens propios (login/refresh se
# eliminaron: el login ocurre en ambientapp.cl).
JWT_SECRET=mismo_valor_que_en_ambientapp

# Origen del frontend — debe matchear exacto (usado por cors({credentials:true}))
CLIENT_URL=https://carbonapp.ambientapp.cl

VALORIZAPP_API_URL=http://localhost:3000
INTERNAL_API_KEY=debe_coincidir_con_INTERNAL_API_KEY_de_valorizapp

# Eria (ambientappIA) — se empuja el resumen de cada período completado a su
# endpoint interno para que pueda responder preguntas sobre los resultados.
ERIA_API_URL=http://localhost:3001
ERIA_INTERNAL_API_KEY=debe_coincidir_con_INTERNAL_API_KEY_de_eria
